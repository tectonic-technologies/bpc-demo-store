{%- comment -%}
  Product Gallery — responsive media gallery for PDP pages.

  Reads media data from product metafields (spectrum.media_assets +
  spectrum.media_slots) per the Media Liquid Metafields contract.

  Desktop: vertical image stack, sticky in PDP left column.
  Mobile: horizontal scroll-snap swipe with progress bar.
  Both: zoom → lightbox, filter panel from filterTags.
{%- endcomment -%}

{% stylesheet %}
/* PDP Gallery (hn2hxz5f) */

/* Product Gallery — aggregated into spectrum-snippet.css at install */

/* ───── 1. Block-root ───── */

.sai-hn2hxz5f {
  position: relative;
  width: 100%;
  z-index: 1;
}

/* ───── 2. Video play/pause overlay ───── */

.sai-hn2hxz5f__video-play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: none;
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 40%, transparent));
  color: var(--sai-color-bg);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: opacity var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out),
    background var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out);
  opacity: 0;
  pointer-events: auto;
}

.sai-hn2hxz5f__video-play[data-visible] {
  opacity: 1;
}

.sai-hn2hxz5f__image-block:hover .sai-hn2hxz5f__video-play,
.sai-hn2hxz5f__slide:hover .sai-hn2hxz5f__video-play,
.sai-hn2hxz5f__lightbox-video-wrap:hover .sai-hn2hxz5f__video-play {
  opacity: 0.8;
}

.sai-hn2hxz5f__video-play:hover {
  opacity: 1 !important;
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 55%, transparent));
}

@media (hover: none) {
  .sai-hn2hxz5f__video-play {
    opacity: 0.7;
  }

  .sai-hn2hxz5f__lightbox-video-wrap .sai-hn2hxz5f__video-play {
    opacity: 0.7;
  }
}

.sai-hn2hxz5f__video-mute {
  position: absolute;
  bottom: var(--sai-size-3);
  left: var(--sai-size-3);
  z-index: 2;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: none;
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 40%, transparent));
  color: var(--sai-color-bg);
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: opacity var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out),
    background var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out);
}

.sai-hn2hxz5f__video-mute[data-visible] {
  display: flex;
}

.sai-hn2hxz5f__video-mute:hover {
  background: var(--sai-color-surface-overlay, color-mix(in srgb, var(--sai-color-fg) 55%, transparent));
}

@media (hover: none) {
  .sai-hn2hxz5f__video-mute[data-visible] {
    display: flex;
  }
}

.sai-hn2hxz5f__slide .sai-hn2hxz5f__video-mute {
  bottom: calc(var(--sai-size-3) + 44px);
}

:has(> .sai-hn2hxz5f__zoom:not([style*="display: none"])) > .sai-hn2hxz5f__video-mute {
  bottom: calc(var(--sai-size-3) + 44px);
}

/* ───── 3. Select model CTA ───── */

.sai-hn2hxz5f__select-model {
  position: absolute;
  bottom: 12px;
  right: 12px;
  z-index: 10;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 10%, transparent);
  border-radius: 999px;
  background: var(--sai-color-bg, #fff);
  color: var(--sai-color-fg, #000);
  cursor: pointer;
  display: none;
  align-items: center;
  height: 36px;
  gap: 6px;
  padding: 0 14px;
  font-family: var(--sai-font-body, inherit);
  font-size: 0.8125rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  line-height: 1;
  white-space: nowrap;
  transition: background var(--sai-duration-2, 150ms) var(--sai-ease-out-1, ease-out);
}

.sai-hn2hxz5f__select-model[data-has-filters] {
  display: flex;
}

.sai-hn2hxz5f__select-model:hover {
  opacity: 0.8;
}

/* ── Filter dialog ── */

.sai-hn2hxz5f__filter-dialog {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  top: auto;
  width: 100%;
  max-width: 100%;
  max-height: 60vh;
  margin: 0;
  padding: 0;
  border: none;
  background: var(--sai-color-bg, #fff);
  color: var(--sai-color-fg, #000);
  border-radius: 16px 16px 0 0;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -4px 24px color-mix(in srgb, var(--sai-color-fg, #000) 12%, transparent);
}

.sai-hn2hxz5f__filter-dialog[open] {
  animation: sai-hn2hxz5f-slide-up 0.25s var(--sai-ease-out-1, ease-out);
}

.sai-hn2hxz5f__filter-dialog::backdrop {
  background: color-mix(in srgb, var(--sai-color-fg, #000) 40%, transparent);
  -webkit-backdrop-filter: blur(2px);
  backdrop-filter: blur(2px);
  animation: sai-hn2hxz5f-fade-in 0.25s ease-out;
}

.sai-hn2hxz5f__filter-dialog[open] .sai-hn2hxz5f__filter-panel {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
}

@keyframes sai-hn2hxz5f-slide-up {
  from {
    transform: translateY(30px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes sai-hn2hxz5f-fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.sai-hn2hxz5f__filter-panel {
  display: none;
}

@keyframes sai-hn2hxz5f-scale-in {
  from {
    transform: translate(-50%, -50%) scale(0.95);
    opacity: 0;
  }
  to {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }
}

@media (min-width: 768px) {
  .sai-hn2hxz5f__filter-dialog {
    bottom: auto;
    top: 50%;
    left: 50%;
    right: auto;
    width: auto;
    transform: translate(-50%, -50%);
    border-radius: 12px;
    min-width: 360px;
    max-width: 440px;
    max-height: 70vh;
    box-shadow: 0 8px 32px color-mix(in srgb, var(--sai-color-fg, #000) 15%, transparent);
  }

  .sai-hn2hxz5f__filter-dialog[open] {
    animation: sai-hn2hxz5f-scale-in 0.25s var(--sai-ease-out-1, ease-out);
  }
}

.sai-hn2hxz5f__filter-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 8%, transparent);
  flex-shrink: 0;
}

.sai-hn2hxz5f__filter-panel-title {
  font-family: var(--sai-font-heading, inherit);
  font-size: 1.125rem;
  font-weight: var(--sai-font-heading-weight, 600);
  color: var(--sai-color-fg, #000);
}

.sai-hn2hxz5f__filter-panel-clear {
  border: none;
  background: none;
  color: var(--sai-color-fg, #000);
  font-family: var(--sai-font-body, inherit);
  font-size: 0.9375rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  cursor: pointer;
  opacity: 0.6;
  padding: 4px 0;
  text-decoration: underline;
}

.sai-hn2hxz5f__filter-panel-clear:hover {
  opacity: 1;
}

.sai-hn2hxz5f__filter-panel-footer {
  display: flex;
  gap: 8px;
  padding: 16px 20px;
  border-top: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 8%, transparent);
  flex-shrink: 0;
}

.sai-hn2hxz5f__filter-panel-cancel {
  flex: 1;
  padding: 10px 16px;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 15%, transparent);
  border-radius: var(--sai-radius-md, 8px);
  background: transparent;
  color: var(--sai-color-fg, #000);
  font-family: var(--sai-font-body, inherit);
  font-size: 0.9375rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  cursor: pointer;
}

.sai-hn2hxz5f__filter-panel-cancel:hover {
  background: color-mix(in srgb, var(--sai-color-fg, #000) 5%, transparent);
}

.sai-hn2hxz5f__filter-panel-apply {
  flex: 1;
  padding: 10px 16px;
  border: none;
  border-radius: var(--sai-radius-md, 8px);
  background: var(--sai-color-fg, #000);
  color: var(--sai-color-bg, #fff);
  font-family: var(--sai-font-body, inherit);
  font-size: 0.9375rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  cursor: pointer;
}

.sai-hn2hxz5f__filter-panel-apply:hover {
  opacity: 0.9;
}

@media (min-width: 768px) {
  .sai-hn2hxz5f__filter-panel-header {
    padding: 20px 24px;
  }

  .sai-hn2hxz5f__filter-panel-title {
    font-size: 1.25rem;
  }

  .sai-hn2hxz5f__filter-panel-clear {
    font-size: 0.9375rem;
  }

  .sai-hn2hxz5f__filters {
    padding: 20px 24px;
  }

  .sai-hn2hxz5f__filter-panel-footer {
    padding: 20px 24px;
  }

  .sai-hn2hxz5f__filter-panel-cancel,
  .sai-hn2hxz5f__filter-panel-apply {
    font-size: 1rem;
    padding: 12px 20px;
  }
}

.sai-hn2hxz5f__filters {
  padding: 0;
  overflow-y: auto;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* ── Filter tabs ── */

.sai-hn2hxz5f__filter-tabs {
  display: flex;
  gap: 0;
  border-bottom: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 8%, transparent);
  padding: 0 20px;
  overflow-x: auto;
  scrollbar-width: none;
}

.sai-hn2hxz5f__filter-tabs::-webkit-scrollbar {
  display: none;
}

.sai-hn2hxz5f__filter-tab {
  padding: 10px 16px;
  border: none;
  background: transparent;
  color: var(--sai-color-fg, #000);
  font-family: var(--sai-font-body, inherit);
  font-size: 0.875rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  cursor: pointer;
  opacity: 0.5;
  border-bottom: 2px solid transparent;
  text-transform: capitalize;
  display: flex;
  align-items: center;
  gap: 4px;
}

.sai-hn2hxz5f__filter-tab--active {
  opacity: 1;
  border-bottom-color: var(--sai-color-fg, #000);
}

.sai-hn2hxz5f__filter-tab-check {
  font-size: 0.75rem;
}

/* ── Filter content (per tab) ── */

.sai-hn2hxz5f__filter-content {
  display: none;
  padding: 16px 20px;
}

.sai-hn2hxz5f__filter-content--active {
  display: block;
}

/* ── Image/swatch grid ── */

.sai-hn2hxz5f__filter-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

@media (min-width: 768px) {
  .sai-hn2hxz5f__filter-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.sai-hn2hxz5f__filter-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 8px;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 10%, transparent);
  border-radius: 8px;
  background: color-mix(in srgb, var(--sai-color-fg, #000) 3%, transparent);
  cursor: pointer;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.sai-hn2hxz5f__filter-card:hover {
  border-color: color-mix(in srgb, var(--sai-color-fg, #000) 25%, transparent);
}

.sai-hn2hxz5f__filter-card--active {
  border-color: var(--sai-color-primary, #2563eb);
  background: color-mix(in srgb, var(--sai-color-primary, #2563eb) 8%, transparent);
}

.sai-hn2hxz5f__filter-card-image {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  border-radius: 4px;
}

.sai-hn2hxz5f__filter-card-swatch {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 4px;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 10%, transparent);
}

.sai-hn2hxz5f__filter-card-label {
  font-size: 0.8125rem;
  font-family: var(--sai-font-body, inherit);
  color: var(--sai-color-fg, #000);
  text-transform: capitalize;
  text-align: center;
}

/* ── Text/null pill chips ── */

.sai-hn2hxz5f__filter-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.sai-hn2hxz5f__filter-pill {
  display: inline-flex;
  align-items: center;
  height: 36px;
  padding: 0 16px;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 15%, transparent);
  border-radius: 999px;
  background: transparent;
  color: var(--sai-color-fg, #000);
  font-size: 0.875rem;
  font-family: var(--sai-font-body, inherit);
  cursor: pointer;
  text-transform: capitalize;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.sai-hn2hxz5f__filter-pill:hover {
  border-color: color-mix(in srgb, var(--sai-color-fg, #000) 35%, transparent);
}

.sai-hn2hxz5f__filter-pill--active {
  background: var(--sai-color-fg, #000);
  color: var(--sai-color-bg, #fff);
  border-color: var(--sai-color-fg, #000);
}

.sai-hn2hxz5f__empty {
  padding: 24px 0;
  text-align: center;
  font-size: 0.875rem;
  font-family: var(--sai-font-body, inherit);
  color: var(--sai-color-fg, #000);
  opacity: 0.6;
}

/* ───── 3. Desktop: vertical image stack, sticky ───── */

.sai-hn2hxz5f__desktop {
  display: none;
}

@media (min-width: 768px) {
  .sai-hn2hxz5f__desktop {
    display: block;
    position: sticky;
    top: 0;
    align-self: start;
  }

  .sai-hn2hxz5f__mobile {
    display: none;
  }
}

.sai-hn2hxz5f__image-block {
  position: relative;
  background: color-mix(in srgb, var(--sai-color-fg, #000) 4%, transparent);
  aspect-ratio: var(--sai-hn2hxz5f-spotlight-aspect, 1 / 1);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.sai-hn2hxz5f__media {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: var(--sai-hn2hxz5f-spotlight-fit, cover);
}

.sai-hn2hxz5f__image-block--video {
  /* Style node target — per-instance video styling applied via baked CSS */
}

.sai-hn2hxz5f__image-block--unavailable {
  display: none;
}

.sai-hn2hxz5f__slide--unavailable {
  display: none;
}

/* ── Zoom button ── */

.sai-hn2hxz5f__zoom {
  position: absolute;
  bottom: 12px;
  left: 12px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 10%, transparent);
  background: var(--sai-color-bg, #fff);
  color: var(--sai-color-fg, #000);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  z-index: 2;
}

.sai-hn2hxz5f__zoom:hover {
  opacity: 0.8;
}

/* ───── 4. Mobile: horizontal swipe ───── */

.sai-hn2hxz5f__mobile {
  position: relative;
  overflow: hidden;
}

.sai-hn2hxz5f__track {
  display: flex;
  overflow-x: scroll;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  width: 100%;
  touch-action: manipulation;
}

.sai-hn2hxz5f__track::-webkit-scrollbar {
  display: none;
}

.sai-hn2hxz5f__slide {
  position: relative;
  flex: 0 0 100%;
  width: 100%;
  min-width: 100%;
  scroll-snap-align: start;
  background: color-mix(in srgb, var(--sai-color-fg, #000) 4%, transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: var(--sai-hn2hxz5f-spotlight-aspect, 1 / 1);
  overflow: hidden;
  cursor: pointer;
}

.sai-hn2hxz5f__slide-media {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: var(--sai-hn2hxz5f-spotlight-fit, cover);
}

/* Natural-height mode: the ratio constraint is dropped, so each image's own
   aspect drives the container height. `height: 100%` on the media would
   resolve to zero against an auto-height container, so the media switches to
   natural height and contain (nothing to crop into). */
sai-hn2hxz5f[data-spotlight-aspect="auto"] .sai-hn2hxz5f__image-block,
sai-hn2hxz5f[data-spotlight-aspect="auto"] .sai-hn2hxz5f__slide {
  aspect-ratio: auto;
  height: auto;
}

sai-hn2hxz5f[data-spotlight-aspect="auto"] .sai-hn2hxz5f__media,
sai-hn2hxz5f[data-spotlight-aspect="auto"] .sai-hn2hxz5f__slide-media {
  height: auto;
  max-height: none;
  object-fit: contain;
}

/* ── Progress bar ── */

.sai-hn2hxz5f__progress {
  display: block !important;
  width: 100%;
  height: 3px;
  background: color-mix(in srgb, var(--sai-color-fg, #000) 12%, transparent);
  overflow: hidden;
}

.sai-hn2hxz5f__progress-bar {
  display: block !important;
  height: 100%;
  background: var(--sai-color-fg, #000);
  transition: width 0.2s ease;
}

/* ── Mobile zoom button ── */

.sai-hn2hxz5f__zoom--mobile {
  position: absolute;
  bottom: 12px;
  left: 12px;
  margin: 0;
  float: none;
  margin-top: 0;
}

/* ───── 5. Lightbox ───── */

.sai-hn2hxz5f__lightbox {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  border: none;
  padding: 0;
  margin: 0;
  background: var(--sai-color-bg, #fff);
  z-index: 9999;
}

.sai-hn2hxz5f__lightbox::backdrop {
  background: color-mix(in srgb, var(--sai-color-fg, #000) 50%, transparent);
  animation: sai-hn2hxz5f-fade-in 0.2s ease-out;
}

.sai-hn2hxz5f__lightbox[open] {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: sai-hn2hxz5f-fade-in 0.2s ease-out;
}

.sai-hn2hxz5f__lightbox-close {
  position: fixed;
  top: 12px;
  right: 12px;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid color-mix(in srgb, var(--sai-color-fg, #000) 10%, transparent);
  background: var(--sai-color-bg, #fff);
  color: var(--sai-color-fg, #000);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  z-index: 10000;
}

.sai-hn2hxz5f__lightbox-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: var(--sai-size-4, 16px);
}

.sai-hn2hxz5f__lightbox-scroll img,
.sai-hn2hxz5f__lightbox-scroll video,
.sai-hn2hxz5f__lightbox-scroll spectrum-video {
  display: block;
  width: 100%;
  height: auto;
  object-fit: var(--sai-hn2hxz5f-lightbox-fit, contain);
  margin-bottom: var(--sai-size-2, 8px);
  opacity: 0;
  transition: opacity 0.2s ease;
}

.sai-hn2hxz5f__lightbox-scroll .sai-hn2hxz5f--loaded {
  opacity: 1;
}

.sai-hn2hxz5f__lightbox-video-wrap {
  position: relative;
  width: 100%;
  margin-bottom: var(--sai-size-2, 8px);
  opacity: 0;
  transition: opacity 0.2s ease;
}

.sai-hn2hxz5f__lightbox-video-wrap.sai-hn2hxz5f--loaded {
  opacity: 1;
}

.sai-hn2hxz5f__lightbox-video-wrap video {
  display: block;
  width: 100%;
  height: auto;
  margin-bottom: 0;
  opacity: 1;
}
/* ───── Native fallback: no Spectrum metafields yet — show native product.media ───── */
.sai-hn2hxz5f__native {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.sai-hn2hxz5f__native-item {
  width: 100%;
}
.sai-hn2hxz5f__native-media,
.sai-hn2hxz5f__native-item img,
.sai-hn2hxz5f__native-item video,
.sai-hn2hxz5f__native-item model-viewer,
.sai-hn2hxz5f__native-item iframe {
  display: block;
  width: 100%;
  height: auto;
}

/* Closed <dialog> guard: some merchant themes ship the legacy reset
   `dialog { display: block }`, an author rule that overrides the UA
   `dialog:not([open])` default and would otherwise leave these overlays
   painting over the page while closed. Hide them explicitly; the [open]
   rules restore display when the dialog opens. */
.sai-hn2hxz5f__lightbox:not([open]),
.sai-hn2hxz5f__filter-dialog:not([open]) { display: none; }
{% endstylesheet %}

{%- assign asset_list = product.metafields.spectrum.media_assets.value -%}

{%- assign selected_variant = product.selected_or_first_available_variant -%}
{%- assign variant_slots = selected_variant.metafields.spectrum.media_slots.value -%}
{%- assign product_slots = product.metafields.spectrum.media_slots.value -%}

{%- comment -%}
  Variant-specific gallery is opt-in. When on, the selected variant's own gallery
  wins and falls back to the product gallery when the variant has none. When off
  (the default), the product gallery always shows: variant slots are ignored here
  and withheld from the client pool below so variant changes never swap galleries.
{%- endcomment -%}
{%- assign enable_variant_gallery = variant.content.enable_variant_gallery -%}
{%- if enable_variant_gallery == nil -%}{%- assign enable_variant_gallery = false -%}{%- endif -%}

{%- assign slot = nil -%}
{%- if enable_variant_gallery and variant_slots != blank and variant_slots['gallery'] != blank -%}
  {%- assign slot = variant_slots['gallery'] -%}
{%- elsif product_slots != blank and product_slots['gallery'] != blank -%}
  {%- assign slot = product_slots['gallery'] -%}
{%- endif -%}

{%- assign slot_variant = nil -%}
{%- if slot != blank -%}
  {%- for candidate in slot.variants -%}
    {%- if candidate.targeting == blank -%}
      {%- assign slot_variant = candidate -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign asset_handles = slot_variant.assets -%}
{%- assign asset_count = 0 -%}
{%- if asset_handles != blank -%}
  {%- assign asset_count = asset_handles.size -%}
{%- endif -%}

{%- comment -%} ── Resolve props from variant.content with defaults ── {%- endcomment -%}
{%- assign _c = variant.content -%}
{%- if _c.autoplay == nil -%}{%- assign autoplay = false -%}{%- else -%}{%- assign autoplay = _c.autoplay -%}{%- endif -%}
{%- if _c.autoplay_interval == nil -%}{%- assign autoplay_interval = 5 -%}{%- else -%}{%- assign autoplay_interval = _c.autoplay_interval -%}{%- endif -%}
{%- if _c.swipe_enabled == nil -%}{%- assign swipe_enabled = true -%}{%- else -%}{%- assign swipe_enabled = _c.swipe_enabled -%}{%- endif -%}
{%- if _c.show_zoom_controls == nil -%}{%- assign show_zoom_controls = true -%}{%- else -%}{%- assign show_zoom_controls = _c.show_zoom_controls -%}{%- endif -%}
{%- if _c.spotlight_object_fit == nil or _c.spotlight_object_fit == blank -%}{%- assign spotlight_object_fit = 'contain' -%}{%- else -%}{%- assign spotlight_object_fit = _c.spotlight_object_fit -%}{%- endif -%}
{%- if _c.lightbox_object_fit == nil or _c.lightbox_object_fit == blank -%}{%- assign lightbox_object_fit = 'contain' -%}{%- else -%}{%- assign lightbox_object_fit = _c.lightbox_object_fit -%}{%- endif -%}
{%- comment -%} Aspect ratio of the main image container. Unknown / missing values fall back to the square default (generated-liquid rule #2). {%- endcomment -%}
{%- if _c.spotlight_aspect_ratio == nil or _c.spotlight_aspect_ratio == blank -%}{%- assign spotlight_aspect_ratio = '1 / 1' -%}{%- else -%}{%- assign spotlight_aspect_ratio = _c.spotlight_aspect_ratio -%}{%- endif -%}
{%- if spotlight_aspect_ratio == 'custom' -%}
  {%- comment -%} Custom ratio: parse "W / H" and re-emit the COERCED numbers, never the raw input, so only digits / dot / slash / space can reach the inline <style> (generated-liquid rule #5). Non-numeric or non-positive falls back to square. {%- endcomment -%}
  {%- assign _spot_parts = _c.spotlight_aspect_ratio_custom | split: '/' -%}
  {%- assign spotlight_aspect_ratio = '1 / 1' -%}
  {%- if _spot_parts.size == 2 -%}
    {%- assign _spot_w = _spot_parts[0] | strip | times: 1.0 -%}
    {%- assign _spot_h = _spot_parts[1] | strip | times: 1.0 -%}
    {%- if _spot_w > 0 and _spot_h > 0 -%}
      {%- assign spotlight_aspect_ratio = _spot_w | append: ' / ' | append: _spot_h -%}
    {%- endif -%}
  {%- endif -%}
{%- else -%}
  {%- assign _valid_spot_ars = '1 / 1|4 / 5|3 / 4|2 / 3|4 / 3|3 / 2|16 / 9|auto' | split: '|' -%}
  {%- unless _valid_spot_ars contains spotlight_aspect_ratio -%}{%- assign spotlight_aspect_ratio = '1 / 1' -%}{%- endunless -%}
{%- endif -%}
{%- if _c.autoplay_video == nil -%}{%- assign autoplay_video = true -%}{%- else -%}{%- assign autoplay_video = _c.autoplay_video -%}{%- endif -%}
{%- if _c.show_play_pause == nil -%}{%- assign show_play_pause = true -%}{%- else -%}{%- assign show_play_pause = _c.show_play_pause -%}{%- endif -%}
{%- if _c.filter_cta_label == nil or _c.filter_cta_label == blank -%}{%- assign filter_cta_label = 'Select model' -%}{%- else -%}{%- assign filter_cta_label = _c.filter_cta_label -%}{%- endif -%}

{%- if asset_count > 0 -%}
<script src="{{ 'sai-snippet-hn2hxz5f.js' | asset_url }}" async></script>
<sai-hn2hxz5f
  class="sai-hn2hxz5f"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ selected_variant.id }}"
  data-asset-count="{{ asset_count }}"
  data-autoplay="{{ autoplay }}"
  data-autoplay-interval="{{ autoplay_interval }}"
  data-swipe-enabled="{{ swipe_enabled }}"
  data-show-zoom-controls="{{ show_zoom_controls }}"
  data-autoplay-video="{{ autoplay_video }}"
  data-show-play-pause="{{ show_play_pause }}"
  data-spotlight-aspect="{{ spotlight_aspect_ratio }}"
>
  <style>
    sai-hn2hxz5f {
      --sai-hn2hxz5f-spotlight-fit: {{ spotlight_object_fit }};
      --sai-hn2hxz5f-lightbox-fit: {{ lightbox_object_fit }};
      --sai-hn2hxz5f-spotlight-aspect: {{ spotlight_aspect_ratio }};
    }
  </style>
  {%- comment -%} ── Filter dialog (bottom sheet on mobile, centered on desktop) ── {%- endcomment -%}
  <dialog class="sai-hn2hxz5f__filter-dialog" aria-label="Filter images">
    <div class="sai-hn2hxz5f__filter-panel">
      <div class="sai-hn2hxz5f__filter-panel-header">
        <span class="sai-hn2hxz5f__filter-panel-title">Filters</span>
        <button class="sai-hn2hxz5f__filter-panel-clear" type="button" data-action="clear-filters" style="display:none">Clear all</button>
      </div>
      <div class="sai-hn2hxz5f__filter-tabs"></div>
      <div class="sai-hn2hxz5f__filters"></div>
      <div class="sai-hn2hxz5f__filter-panel-footer">
        <button class="sai-hn2hxz5f__filter-panel-cancel" type="button" data-action="close-filters">Cancel</button>
        <button class="sai-hn2hxz5f__filter-panel-apply" type="button" data-action="apply-filters">Apply</button>
      </div>
    </div>
  </dialog>


  {%- comment -%} ── Desktop: vertical stack of images ── {%- endcomment -%}
  <div class="sai-hn2hxz5f__desktop">
    {%- for handle in asset_handles -%}
      {%- assign img_asset = nil -%}
      {%- for asset_ref in asset_list -%}
        {%- if asset_ref.system.handle == handle -%}
          {%- assign img_asset = asset_ref -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if img_asset != blank -%}
        <div class="sai-hn2hxz5f__image-block{% if forloop.first %} sai-hn2hxz5f__image-block--first{% endif %}{% if img_asset.asset_type == 'video' %} sai-hn2hxz5f__image-block--video{% endif %}" data-index="{{ forloop.index0 }}" data-handle="{{ handle }}">
          {%- if img_asset.asset_type == 'video' -%}
            {%- assign vid_file = img_asset.file.value | default: img_asset.file -%}
            {%- assign vid_url = '' -%}
            {%- if vid_file.sources != blank -%}
              {%- for source in vid_file.sources -%}
                {%- if source.format == 'mp4' and vid_url == '' -%}
                  {%- assign vid_url = source.url -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if vid_url == '' -%}
                {%- assign vid_url = vid_file.sources.first.url -%}
              {%- endif -%}
            {%- elsif vid_file.url != blank -%}
              {%- assign vid_url = vid_file.url -%}
            {%- endif -%}
            <video
              class="sai-hn2hxz5f__media"
              src="{{ vid_url }}"
              {%- if autoplay_video == true %} autoplay{% endif %}
              {%- if autoplay_video == true %} muted{% endif %}
              loop playsinline
              {%- if vid_file.preview_image != blank %} poster="{{ vid_file.preview_image | image_url: width: 1200 }}"{% endif %}
            ></video>
          {%- else -%}
            <img
              class="sai-hn2hxz5f__media"
              src="{{ img_asset.file | image_url: width: 1200 }}"
              alt="{{ img_asset.alt | escape }}"
              width="{{ img_asset.file.width }}"
              height="{{ img_asset.file.height }}"
              {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
            />
          {%- endif -%}
          {%- if forloop.first -%}
            <button class="sai-hn2hxz5f__zoom" type="button" aria-label="Zoom image" data-action="open-lightbox">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
                <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M8 11h6M11 8v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
            <button class="sai-hn2hxz5f__select-model" type="button" data-action="toggle-filters" aria-label="{{ filter_cta_label }}">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                <path d="M3 6h18M7 12h10M10 18h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
              {{ filter_cta_label }}
            </button>
          {%- endif -%}
        </div>
      {%- else -%}
        <!-- spectrum:debug handle={{ handle }} missing from asset library -->
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} ── Mobile: horizontal swipe ── {%- endcomment -%}
  <div class="sai-hn2hxz5f__mobile">
    <div class="sai-hn2hxz5f__track">
      {%- for handle in asset_handles -%}
        {%- assign slide_asset = nil -%}
        {%- for asset_ref in asset_list -%}
          {%- if asset_ref.system.handle == handle -%}
            {%- assign slide_asset = asset_ref -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if slide_asset != blank -%}
          <div class="sai-hn2hxz5f__slide" data-index="{{ forloop.index0 }}" data-handle="{{ handle }}">
            {%- if slide_asset.asset_type == 'video' -%}
              {%- assign s_vid_file = slide_asset.file.value | default: slide_asset.file -%}
              {%- assign s_vid_url = '' -%}
              {%- if s_vid_file.sources != blank -%}
                {%- for source in s_vid_file.sources -%}
                  {%- if source.format == 'mp4' and s_vid_url == '' -%}
                    {%- assign s_vid_url = source.url -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- if s_vid_url == '' -%}
                  {%- assign s_vid_url = s_vid_file.sources.first.url -%}
                {%- endif -%}
              {%- elsif s_vid_file.url != blank -%}
                {%- assign s_vid_url = s_vid_file.url -%}
              {%- endif -%}
              <video
                class="sai-hn2hxz5f__slide-media"
                src="{{ s_vid_url }}"
                {%- if autoplay_video == true %} autoplay{% endif %}
              {%- if autoplay_video == true %} muted{% endif %}
              loop playsinline
                {%- if s_vid_file.preview_image != blank %} poster="{{ s_vid_file.preview_image | image_url: width: 800 }}"{% endif %}
              ></video>
            {%- else -%}
              <img
                class="sai-hn2hxz5f__slide-media"
                src="{{ slide_asset.file | image_url: width: 800 }}"
                alt="{{ slide_asset.alt | escape }}"
                width="{{ slide_asset.file.width }}"
                height="{{ slide_asset.file.height }}"
                {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
              />
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if asset_count > 1 -%}
      <div class="sai-hn2hxz5f__progress">
        <div class="sai-hn2hxz5f__progress-bar" style="width: 0%">&#8203;</div>
      </div>
    {%- endif -%}

    <button class="sai-hn2hxz5f__zoom sai-hn2hxz5f__zoom--mobile" type="button" aria-label="Zoom image" data-action="open-lightbox">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
        <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M8 11h6M11 8v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <button class="sai-hn2hxz5f__select-model" type="button" data-action="toggle-filters" aria-label="{{ filter_cta_label }}">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
        <path d="M3 6h18M7 12h10M10 18h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      {{ filter_cta_label }}
    </button>
  </div>

  {%- comment -%} ── Lightbox ── {%- endcomment -%}
  <dialog class="sai-hn2hxz5f__lightbox" aria-modal="true" aria-label="Product gallery">
    <button class="sai-hn2hxz5f__lightbox-close" type="button" data-action="close-lightbox" aria-label="Close gallery">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false">
        <path d="M1.5 1.5L12.5 12.5M12.5 1.5L1.5 12.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="sai-hn2hxz5f__lightbox-scroll"></div>
  </dialog>
</sai-hn2hxz5f>

{%- comment -%}
  Bespoke pool — pre-loads all assets + variant slots.
  O(n) handle lookup: JS builds a Map from this, no nested iteration.
{%- endcomment -%}
<script type="application/json" data-spectrum-snippet-pool>
{
  "assets": {
    {%- assign first_asset_emitted = false -%}
    {%- for asset_ref in asset_list -%}
      {%- assign a_handle = asset_ref.system.handle -%}
      {%- assign a_type = asset_ref.asset_type | default: 'image' -%}
      {%- assign a_url = '' -%}
      {%- assign a_width = 0 -%}
      {%- assign a_height = 0 -%}

      {%- assign a_thumb = '' -%}
      {%- if a_type == 'video' -%}
        {%- assign a_file = asset_ref.file.value | default: asset_ref.file -%}
        {%- if a_file.sources != blank -%}
          {%- for source in a_file.sources -%}
            {%- if source.format == 'mp4' and a_url == '' -%}
              {%- assign a_url = source.url -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if a_url == '' -%}
            {%- assign a_url = a_file.sources.first.url -%}
          {%- endif -%}
        {%- elsif a_file.url != blank -%}
          {%- assign a_url = a_file.url -%}
        {%- endif -%}
        {%- if a_file.preview_image != blank -%}
          {%- assign a_thumb = a_file.preview_image | image_url: width: 120 -%}
        {%- endif -%}
      {%- else -%}
        {%- assign a_url = asset_ref.file | image_url: width: 1200 -%}
        {%- assign a_thumb = asset_ref.file | image_url: width: 120 -%}
        {%- assign a_width = asset_ref.file.width -%}
        {%- assign a_height = asset_ref.file.height -%}
      {%- endif -%}

      {%- unless first_asset_emitted -%}{%- assign first_asset_emitted = true -%}{%- else -%},{%- endunless -%}
      {{ a_handle | json }}: {
        "id": {{ asset_ref.asset_id | json }},
        "type": {{ a_type | json }},
        "url": {{ a_url | json }},
        "thumb": {{ a_thumb | json }},
        "alt": {{ asset_ref.alt | default: '' | json }},
        "tags": {
          {%- assign a_tags = asset_ref.tags.value -%}
          {%- if a_tags != blank -%}
            {%- for pair in a_tags -%}
              {%- unless forloop.first -%},{%- endunless -%}
              {{ pair[0] | json }}: {{ pair[1] | json }}
            {%- endfor -%}
          {%- endif -%}
        },
        "width": {{ a_width | json }},
        "height": {{ a_height | json }}
      }
    {%- endfor -%}
  },
  "productSlots": {
    {%- if product_slots != blank -%}
      {%- for pair in product_slots -%}
        {%- unless forloop.first -%},{%- endunless -%}
        {{ pair[0] | json }}: {
          "filterTags": {
            {%- for ft in pair[1].filterTags -%}
              {%- unless forloop.first -%},{%- endunless -%}
              {{ ft[0] | json }}: {{ ft[1] | json }}
            {%- endfor -%}
          },
          "variants": {{ pair[1].variants | json }}
        }
      {%- endfor -%}
    {%- endif -%}
  },
  "variantSlots": {
    {%- comment -%} Withheld unless variant gallery is enabled — keeps the client from swapping galleries on variant change when the feature is off. {%- endcomment -%}
    {%- if enable_variant_gallery -%}
    {%- assign first_vs = true -%}
    {%- for v in product.variants -%}
      {%- assign v_slots = v.metafields.spectrum.media_slots.value -%}
      {%- if v_slots != blank -%}
        {%- unless first_vs -%},{%- endunless -%}
        {%- assign first_vs = false -%}
        {{ v.id | append: '' | json }}: {
          {%- for vpair in v_slots -%}
            {%- unless forloop.first -%},{%- endunless -%}
            {{ vpair[0] | json }}: {
              "filterTags": {
                {%- for vft in vpair[1].filterTags -%}
                  {%- unless forloop.first -%},{%- endunless -%}
                  {{ vft[0] | json }}: {{ vft[1] | json }}
                {%- endfor -%}
              },
              "variants": {{ vpair[1].variants | json }}
            }
          {%- endfor -%}
        }
      {%- endif -%}
    {%- endfor -%}
    {%- endif -%}
  },
  "displayConfigImages": {
    {%- assign first_dci = true -%}
    {%- for asset_ref in asset_list -%}
      {%- assign dca_list = asset_ref.display_config_assets.value -%}
      {%- if dca_list != blank -%}
        {%- for dca_media in dca_list -%}
          {%- unless first_dci -%},{%- endunless -%}
          {%- assign first_dci = false -%}
          {%- capture _dci_gid -%}gid://shopify/MediaImage/{{ dca_media.id }}{%- endcapture -%}
          {{ _dci_gid | json }}: {{ dca_media | image_url: width: 200 | json }}
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}
  }
}
</script>
{%- else -%}
  {%- comment -%}
    Native fallback — the Spectrum gallery metafields are absent or empty (a product still mirroring,
    or one whose only media Spectrum cannot faithfully mirror yet). Render the native product.media so
    the PDP is never blank. Self-contained: no web component, no JS, so it renders whether or not the
    mirror has run, and shows whatever Shopify has natively (including 3D / external video).
  {%- endcomment -%}
  {%- if product.media.size > 0 -%}
    <div class="sai-hn2hxz5f__native">
      {%- for media in product.media -%}
        <div class="sai-hn2hxz5f__native-item">
          {%- if media.media_type == 'image' -%}
            <img
              class="sai-hn2hxz5f__native-media"
              src="{{ media.preview_image | image_url: width: 1200 }}"
              alt="{{ media.alt | escape }}"
              width="{{ media.preview_image.width }}"
              height="{{ media.preview_image.height }}"
              {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
            />
          {%- else -%}
            {{ media | media_tag }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
{%- endif -%}
