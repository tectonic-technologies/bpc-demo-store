{%- doc -%}
  Trust-marker primitive (v1) — icon + text chip, rendered in a loop by a host
  section.

  Immutable once shipped: a behaviour change ships _sai-primitive-pill-v2.liquid
  as a sibling; v1 stays installed and referenced by sections authored against
  it. Byte immutability is pinned by a hardcoded-digest test.

  Rendered in an isolated render scope — reads only its explicit args, no
  caller-scope locals. Renders nothing when text is blank so an empty row never
  leaves a stray chip. Emits no stylesheet block: the sai-pill classes are
  styled by the consuming section (theme tokens only, no baked colours).

  @param {object} marker - one item: { text (required), icon_name?, icon? }.
    Icon resolution, first match wins: uploaded icon.originalUrl → icon.url →
    icon.previewUrl → icon_name preset SVG (currentColor stroke) → neutral dot.
    Preset icon_name values: shield, badge, leaf, check, star, truck, lock,
    heart, refresh, tag, gift. An unknown icon_name falls back to the check glyph.
    Snake_case (not iconName) so an inline-list badge item — whose sub-field
    keys are regex-locked to lowercase+underscore — can be passed straight
    through as `marker` with no per-item hash reconstruction (Liquid has no
    object literals).
  @param {string} layout - 'pill' or 'inline'. Any other value defaults to pill.
{%- enddoc -%}
{%- liquid
  assign marker_text = marker.text
  assign layout_mode = layout
  unless layout_mode == 'inline'
    assign layout_mode = 'pill'
  endunless
  assign icon_src = ''
  if marker.icon.originalUrl != blank
    assign icon_src = marker.icon.originalUrl
  elsif marker.icon.url != blank
    assign icon_src = marker.icon.url
  elsif marker.icon.previewUrl != blank
    assign icon_src = marker.icon.previewUrl
  endif
-%}
{%- if marker_text != blank -%}
  <span class="sai-pill sai-pill--{{ layout_mode }}">
    {%- if icon_src != '' -%}
      <span class="sai-pill__icon"><img src="{{ icon_src | escape }}" alt="" loading="lazy" width="16" height="16"></span>
    {%- elsif marker.icon_name != blank -%}
      <span class="sai-pill__icon" aria-hidden="true">
        {%- case marker.icon_name -%}
          {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
          {%- when 'badge' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="8" r="6"/><path d="M8.21 13.89 7 23l5-3 5 3-1.21-9.12"/></svg>
          {%- when 'leaf' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
          {%- when 'check' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9"/><path d="m8 12 2.5 2.5L16 9"/></svg>
          {%- when 'star' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>
          {%- when 'truck' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M14 17V5a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v11a1 1 0 0 0 1 1h1"/><path d="M14 8h4l3 3v5a1 1 0 0 1-1 1h-1"/><path d="M9 17h6"/><circle cx="6.5" cy="17.5" r="1.8"/><circle cx="17.5" cy="17.5" r="1.8"/></svg>
          {%- when 'lock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
          {%- when 'heart' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3 5.49 5.49 0 0 0 12 5.36 5.49 5.49 0 0 0 7.5 3 5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          {%- when 'refresh' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/></svg>
          {%- when 'tag' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 7v5l9 9 7-7-9-9H4a1 1 0 0 0-1 1Z"/><circle cx="7.5" cy="7.5" r="1.2"/></svg>
          {%- when 'gift' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="3" y="8" width="18" height="4"/><path d="M5 12v9h14v-9"/><path d="M12 8v13"/><path d="M12 8S10 3 7.5 4.5 9 8 12 8Z"/><path d="M12 8s2-5 4.5-3.5S15 8 12 8Z"/></svg>
          {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9"/><path d="m8 12 2.5 2.5L16 9"/></svg>
        {%- endcase -%}
      </span>
    {%- else -%}
      <span class="sai-pill__dot" aria-hidden="true"></span>
    {%- endif -%}
    <span class="sai-pill__text">{{ marker_text | escape }}</span>
  </span>
{%- endif -%}
