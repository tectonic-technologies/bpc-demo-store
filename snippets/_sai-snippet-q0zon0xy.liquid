    animation-duration: 1ms !important;
  }
}

.sai-q0zon0xy__modal-card {
  background: var(--sai-q0zon0xy-modal-card-bg);
  border-radius: 16px;
  inline-size: 100%;
  max-inline-size: 34rem;
