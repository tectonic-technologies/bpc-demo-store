/* ── Modal ───────────────────────────────────────────────────────────────── */

.sai-q0zon0xy__modal-overlay {
  position: fixed;
  inset: 0;
  background: var(--sai-q0zon0xy-modal-overlay-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2147483000;
  padding: 1rem;
  font-family: var(--sai-font-body, inherit);
  color: var(--sai-q0zon0xy-fg);
  box-sizing: border-box;
  animation: sai-q0zon0xy-overlay-in 220ms ease forwards;
}

.sai-q0zon0xy__modal-overlay[data-closing="true"] {
  animation: sai-q0zon0xy-overlay-out 220ms ease forwards;
  pointer-events: none;
}

.sai-q0zon0xy__modal-overlay *,
.sai-q0zon0xy__modal-overlay *::before,
.sai-q0zon0xy__modal-overlay *::after {
  box-sizing: border-box;
}

@keyframes sai-q0zon0xy-overlay-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes sai-q0zon0xy-overlay-out {
  from {
    opacity: 1;
  }
  to {
    opacity: 0;
  }
}

@keyframes sai-q0zon0xy-card-in {
  from {
    transform: translateY(100vh);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes sai-q0zon0xy-card-out {
  from {
    transform: translateY(0);
  }
  to {
    transform: translateY(100vh);
  }
}

@media (prefers-reduced-motion: reduce) {
