  will-change: transform;
}

.sai-q0zon0xy__modal-overlay[data-closing="true"] .sai-q0zon0xy__modal-card {
  animation: sai-q0zon0xy-card-out 260ms cubic-bezier(0.4, 0, 0.6, 1) forwards;
}

.sai-q0zon0xy__modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  gap: var(--sai-size-3);
}

.sai-q0zon0xy__modal-close {
