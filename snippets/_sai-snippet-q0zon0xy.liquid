{% doc %}
  Frequently Bought Together — bundle widget on the PDP.

  Two layouts: `vertical` (cards stacked above CTA, total inline in CTA)
  and `horizontal` (cards side by side with `+` separators, right-side
  Total panel hosting the CTA). Selection / variant picker / batched
  cart-add are identical across both.

  @param entry                {SlotEnvelopeEntry} Resolved default entry
                                                  from spectrum.fbt_<draft|live>;
                                                  `entry.content.recommendations`
                                                  is the array of product
                                                  handles to render as
                                                  recommendations.
  @param variant              {Metaobject}        Default variant from
                                                  spectrum_snippet_instance;
                                                  `variant.content` carries
                                                  merchant-edited props.
  @param mo                   {Metaobject}        spectrum_snippet_instance
                                                  metaobject drop.
  @param mutation_handle      {string}            'mut-{instanceId}' —
                                                  consumed by the wrapper's
                                                  outer div, not this body.
  @param experience_handle    {string}            Consumed by the wrapper's
                                                  outer div.
{% enddoc %}

{%- comment -%}
  Liquid globals used inside this snippet (NOT render args — Shopify-native):
    - product            : the page's main product (PDP context).
    - all_products       : handle-keyed product lookup. Capped at 20 unique
                           handles per page across the whole render — well
                           above the FBT count.
    - shop               : currency code threaded into the JSON payload.

  Empty / nil `entry.content.recommendations` collapses the whole widget.

  Trust boundary: this snippet does NOT receive merchant-authored HTML —
  every text prop (`heading`, `cta_label`, `section_description`,
  `total_label`, `total_subtext`) is run through `| escape` defensively so
  a merchant who pastes markup into a text field can't break the page
  layout or inject content.
{%- endcomment -%}

{% stylesheet %}
/* =============================================================================
 * Frequently Bought Together (q0zon0xy) — combined vertical + horizontal CSS.
 *
 * Shared rules live at the .sai-q0zon0xy root; layout-specific rules are
 * nested under .sai-q0zon0xy--vertical / .sai-q0zon0xy--horizontal. Single
 * author selectors stay at specificity (0,1,0) so per-instance baked rules
 * (anchored on [data-spectrum-instance-id][data-spectrum-variant-id]) always
 * win the cascade.
 *
 * Color tokens use --sai-q0zon0xy-* custom properties so the Studio
 * per-instance style panel can override them. Fonts/spacing/radius come from
 * the theme's --sai-* design tokens — never hardcoded.
 * ============================================================================= */

.sai-q0zon0xy,
.sai-q0zon0xy__modal-overlay {
  --sai-q0zon0xy-card-bg: #ffffff;
  --sai-q0zon0xy-card-border: rgba(0, 0, 0, 0.1);
  --sai-q0zon0xy-card-radius: 12px;
  --sai-q0zon0xy-sub-header-bg: #f4f4f4;
  --sai-q0zon0xy-checkbox-size: 1.5rem;
  --sai-q0zon0xy-image-size: 5.5rem;
  --sai-q0zon0xy-card-w: 11.5rem;
  --sai-q0zon0xy-image-h: 12rem;
  --sai-q0zon0xy-plus-size: 1.75rem;
  --sai-q0zon0xy-off-bg: #0e6f54;
  --sai-q0zon0xy-off-fg: #ffffff;
  --sai-q0zon0xy-rating-fg: #f5b013;
  --sai-q0zon0xy-low-stock-fg: #d24207;
  --sai-q0zon0xy-fg: var(--sai-color-fg, #121212);
  --sai-q0zon0xy-muted-fg: rgba(0, 0, 0, 0.55);
  --sai-q0zon0xy-cta-bg: #ffffff;
  --sai-q0zon0xy-cta-fg: #121212;
  --sai-q0zon0xy-cta-border: #121212;
  --sai-q0zon0xy-cta-hover-bg: #121212;
  --sai-q0zon0xy-cta-hover-fg: #ffffff;
  --sai-q0zon0xy-modal-overlay-bg: rgba(0, 0, 0, 0.55);
  --sai-q0zon0xy-modal-card-bg: #ffffff;
  --sai-q0zon0xy-pill-bg: #ededed;
  --sai-q0zon0xy-pill-fg: #121212;
  --sai-q0zon0xy-pill-selected-bg: #121212;
  --sai-q0zon0xy-pill-selected-fg: #ffffff;
  --sai-q0zon0xy-pill-disabled-fg: rgba(0, 0, 0, 0.45);
  --sai-q0zon0xy-done-bg: #121212;
  --sai-q0zon0xy-done-fg: #ffffff;
  --sai-q0zon0xy-loader-size: 1.125rem;
}

.sai-q0zon0xy {
  display: block;
  box-sizing: border-box;
  inline-size: 100%;
  /* Query container: the horizontal layout must respond to the width it is
     actually placed in (e.g. a narrow PDP details column), not the viewport.
     Viewport media queries below would otherwise apply the wide two-column
     layout inside a narrow column and overflow. */
  container-type: inline-size;
  container-name: sai-q0zon0xy;
  margin-inline: auto;
  margin-block: var(--sai-size-6);
  font-family: var(--sai-font-body);
  font-size: 1rem;
  line-height: 1.4;
  color: var(--sai-q0zon0xy-fg);
}

.sai-q0zon0xy--vertical {
  max-inline-size: 56rem;
  padding-inline: var(--sai-size-4);
  font-size: 1.0625rem;
  line-height: 1.45;
}

.sai-q0zon0xy--horizontal {
  max-inline-size: 75rem;
}

.sai-q0zon0xy *,
.sai-q0zon0xy *::before,
.sai-q0zon0xy *::after {
  box-sizing: border-box;
}

.sai-q0zon0xy__inner {
  inline-size: 100%;
  box-sizing: border-box;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__inner {
  padding-inline: var(--sai-size-4);
}

.sai-q0zon0xy__heading {
  font-family: var(--sai-font-heading, var(--sai-font-body));
  font-size: 1.625rem;
  font-weight: var(--sai-font-body-weight-bold, 700);
  margin-block: 0 var(--sai-size-3);
  letter-spacing: -0.01em;
  line-height: 1.2;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__heading {
  margin-block: 0 var(--sai-size-4);
}

.sai-q0zon0xy__description {
  margin: 0 0 var(--sai-size-4) 0;
  font-size: 0.875rem;
  color: var(--sai-q0zon0xy-muted-fg);
  line-height: 1.4;
}

/* ── Cards (shared base) ─────────────────────────────────────────────────── */

.sai-q0zon0xy__card {
  background: var(--sai-q0zon0xy-card-bg);
  border: 1px solid var(--sai-q0zon0xy-card-border);
  border-radius: var(--sai-q0zon0xy-card-radius);
  overflow: hidden;
}

.sai-q0zon0xy__title {
  color: inherit;
  text-decoration: none;
  font-weight: var(--sai-font-body-weight-bold, 600);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.sai-q0zon0xy__title:hover {
  text-decoration: underline;
}

.sai-q0zon0xy__price-row {
  display: flex;
  gap: var(--sai-size-2);
  flex-wrap: wrap;
}

.sai-q0zon0xy__price {
  font-weight: var(--sai-font-body-weight-bold, 600);
}

.sai-q0zon0xy__compare {
  text-decoration: line-through;
  color: var(--sai-q0zon0xy-muted-fg);
}

.sai-q0zon0xy__off-badge {
  background: var(--sai-q0zon0xy-off-bg);
  color: var(--sai-q0zon0xy-off-fg);
  border-radius: var(--sai-radius-round);
  padding: 0.1875rem var(--sai-size-2);
  font-size: 0.8125rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  letter-spacing: 0.02em;
}

.sai-q0zon0xy__variant-trigger {
  appearance: none;
  background: transparent;
  border: 1px solid var(--sai-q0zon0xy-card-border);
  color: inherit;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sai-size-2);
  font: inherit;
  text-align: start;
}

.sai-q0zon0xy__variant-trigger:hover {
  background: rgba(0, 0, 0, 0.03);
}

.sai-q0zon0xy__variant-label {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sai-q0zon0xy__chevron {
  flex-shrink: 0;
  color: var(--sai-q0zon0xy-muted-fg);
}

/* ── Vertical layout ─────────────────────────────────────────────────────── */

.sai-q0zon0xy--vertical .sai-q0zon0xy__card {
  margin-block-end: var(--sai-size-3);
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__card--main {
  border-color: rgba(0, 0, 0, 0.16);
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__sub-header {
  background: var(--sai-q0zon0xy-sub-header-bg);
  font-size: 1rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
  padding: var(--sai-size-3) var(--sai-size-4);
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__row {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: var(--sai-size-4);
  padding: var(--sai-size-4);
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__media {
  display: block;
  inline-size: var(--sai-q0zon0xy-image-size);
  /* block-size driven by the inline `aspect-ratio` style on this element
     (set from the merchant's image_aspect_ratio prop). Fixed block-size
     here would override the prop. */
  block-size: auto;
  border-radius: var(--sai-radius-2);
  overflow: hidden;
  background: rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__image {
  inline-size: 100%;
  block-size: 100%;
  object-fit: cover;
  display: block;
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__info {
  min-inline-size: 0;
  display: flex;
  flex-direction: column;
  gap: var(--sai-size-2);
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__title {
  font-size: 1.0625rem;
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__price-row {
  align-items: center;
  font-size: 1rem;
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__variant-trigger {
  border-radius: var(--sai-radius-round);
  padding: 0.5rem var(--sai-size-3);
  font-size: 0.9375rem;
  inline-size: fit-content;
  max-inline-size: 100%;
  min-inline-size: 9rem;
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__select {
  display: flex;
  flex-direction: column;
  align-items: end;
  gap: var(--sai-size-3);
  align-self: stretch;
  justify-content: space-between;
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__checkbox {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  inline-size: var(--sai-q0zon0xy-checkbox-size);
  block-size: var(--sai-q0zon0xy-checkbox-size);
  border-radius: var(--sai-radius-2);
  cursor: pointer;
  position: relative;
  background: transparent;
  border: 1.5px solid rgba(0, 0, 0, 0.25);
  transition: background var(--sai-duration-1) var(--sai-ease-out-1), border-color
    var(--sai-duration-1) var(--sai-ease-out-1);
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__checkbox:has(input:checked) {
  background: var(--sai-color-primary);
  border-color: var(--sai-color-primary);
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__checkbox:has(input:checked) .sai-q0zon0xy__checkbox-mark {
  color: var(--sai-color-primary-fg);
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__checkbox:has(input:focus-visible) {
  outline: 2px solid var(--sai-color-primary);
  outline-offset: 2px;
}

.sai-q0zon0xy__checkbox input {
  position: absolute;
  opacity: 0;
  inset: 0;
  margin: 0;
  cursor: pointer;
}

.sai-q0zon0xy__checkbox-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  color: transparent;
}

/* Hide the entire checkbox cell when the main product is locked. The hidden
   <input> stays in the DOM (still checked by SSR + locked) so JS row-init
   counts the main as selected — but the user sees no checkbox at all. */
.sai-q0zon0xy__checkbox--locked {
  display: none !important;
}

/* Hide the whole main-product card while keeping it in the DOM. Used when the
   main product is locked but its card is suppressed: the card's checkbox stays
   present (checked + disabled) so JS still counts it and adds it to cart. */
.sai-q0zon0xy__card--hidden {
  display: none !important;
}

.sai-q0zon0xy__rating {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.9375rem;
  font-weight: var(--sai-font-body-weight-bold, 600);
}

.sai-q0zon0xy__rating svg {
  inline-size: 1rem;
  block-size: 1rem;
  color: var(--sai-q0zon0xy-rating-fg);
}

/* ── Horizontal layout ───────────────────────────────────────────────────── */

.sai-q0zon0xy--horizontal .sai-q0zon0xy__layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: var(--sai-size-4);
  align-items: stretch;
}

@container sai-q0zon0xy (min-width: 768px) {
  .sai-q0zon0xy--horizontal .sai-q0zon0xy__layout {
    grid-template-columns: minmax(0, 1fr) 26rem;
    gap: var(--sai-size-5);
  }
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__cards {
  display: flex;
  align-items: stretch;
  gap: 1rem;
  inline-size: 100%;
  min-inline-size: 0;
  scrollbar-width: thin;
  padding-block: 0.25rem;
  -webkit-overflow-scrolling: touch;
}

@container sai-q0zon0xy (max-width: 767.98px) {
  .sai-q0zon0xy--horizontal .sai-q0zon0xy__cards {
    overflow-x: auto;
  }
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__cards::-webkit-scrollbar {
  block-size: 6px;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__cards::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 999px;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__plus {
  display: flex;
  align-items: center;
  justify-content: center;
  inline-size: var(--sai-q0zon0xy-plus-size);
  block-size: var(--sai-q0zon0xy-plus-size);
  border-radius: 999px;
  border: 1px solid var(--sai-q0zon0xy-card-border);
  background: var(--sai-q0zon0xy-card-bg);
  color: var(--sai-q0zon0xy-fg);
  align-self: center;
  flex-shrink: 0;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__card {
  position: relative;
  flex: 1 1 0;
  min-inline-size: 9.5rem;
  display: flex;
  flex-direction: column;
  gap: var(--sai-size-2);
  padding: var(--sai-size-3);
}

@container sai-q0zon0xy (max-width: 767.98px) {
  .sai-q0zon0xy--horizontal .sai-q0zon0xy__card {
    flex: 0 0 11rem;
  }
}

/* Horizontal checkbox overlays the top-left of the card image. */
.sai-q0zon0xy--horizontal .sai-q0zon0xy__checkbox {
  position: absolute;
  inset-block-start: 0.625rem;
  inset-inline-start: 0.625rem;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  inline-size: 1.375rem;
  block-size: 1.375rem;
  border-radius: 4px;
  cursor: pointer;
  background: #ffffff;
  border: 1.5px solid rgba(0, 0, 0, 0.35);
  transition: background 120ms ease, border-color 120ms ease;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__checkbox:has(input:checked) {
  background: var(--sai-color-primary, #121212);
  border-color: var(--sai-color-primary, #121212);
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__checkbox:has(input:checked) .sai-q0zon0xy__checkbox-mark {
  color: var(--sai-color-primary-fg, #ffffff);
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__checkbox:has(input:focus-visible) {
  outline: 2px solid var(--sai-color-primary, #121212);
  outline-offset: 2px;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__media {
  display: block;
  inline-size: 100%;
  /* aspect-ratio set inline from the merchant's image_aspect_ratio prop.
     Don't hardcode it here — the inline style would still win, but a CSS
     default here makes the prop look broken when the inline value isn't
     present (e.g. during template edits). */
  block-size: auto;
  border-radius: 8px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.04);
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__image {
  inline-size: 100%;
  block-size: 100%;
  object-fit: cover;
  display: block;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__title {
  font-size: 0.875rem;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__price-row {
  align-items: baseline;
  font-size: 0.9375rem;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__compare {
  font-size: 0.8125rem;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__variant-trigger {
  border-radius: 8px;
  padding: 0.4375rem var(--sai-size-2);
  font-size: 0.8125rem;
  inline-size: 100%;
  margin-block-start: auto;
}

/* ── Total panel + CTA (shared visual + layout overrides) ────────────────── */

.sai-q0zon0xy__cta {
  appearance: none;
  inline-size: 100%;
  background: var(--sai-q0zon0xy-cta-bg);
  color: var(--sai-q0zon0xy-cta-fg);
  border: 1.5px solid var(--sai-q0zon0xy-cta-border);
  border-radius: var(--sai-q0zon0xy-card-radius);
  padding: 1rem 1.25rem;
  font: inherit;
  font-size: 1.0625rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: background 120ms ease, color 120ms ease, opacity 120ms ease;
}

.sai-q0zon0xy__cta:hover:not(:disabled) {
  background: var(--sai-q0zon0xy-cta-hover-bg);
  color: var(--sai-q0zon0xy-cta-hover-fg);
}

.sai-q0zon0xy__cta:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.sai-q0zon0xy__error {
  margin-block-start: var(--sai-size-2);
  padding: var(--sai-size-2) var(--sai-size-3);
  background: rgba(197, 48, 48, 0.08);
  color: var(--sai-color-error, #c53030);
  border-radius: var(--sai-radius-2);
  font-size: 0.8125rem;
}

/* Vertical: CTA stacks label + inline total vertically. */
.sai-q0zon0xy--vertical .sai-q0zon0xy__cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.375rem;
  text-align: center;
  line-height: 1.2;
  margin-block-start: var(--sai-size-4);
}

/* The loader is positioned absolute and must keep its own flex display so the
   spinner stays centered. Excluding it from this rule preserves both. */
.sai-q0zon0xy--vertical .sai-q0zon0xy__cta > span:not(.sai-q0zon0xy__loader) {
  display: block;
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__total--inline {
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  opacity: 0.92;
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__total-inline-label {
  text-transform: uppercase;
  letter-spacing: 0.04em;
  font-weight: 600;
}

.sai-q0zon0xy--vertical .sai-q0zon0xy__total-separator {
  opacity: 0.6;
}

/* Hide the inline total line entirely when no amount is rendered yet. */
.sai-q0zon0xy--vertical .sai-q0zon0xy__total--inline:has(.sai-q0zon0xy__total-amount:empty) {
  display: none;
}

/* Horizontal: right-side total panel layout. */
.sai-q0zon0xy--horizontal .sai-q0zon0xy__total--panel {
  display: flex;
  flex-direction: column;
  gap: var(--sai-size-3);
  padding-inline: var(--sai-size-2);
  align-self: stretch;
  justify-content: flex-start;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__cta {
  background: var(--sai-q0zon0xy-cta-hover-bg);
  color: var(--sai-q0zon0xy-cta-hover-fg);
  border: none;
  margin-block-start: auto;
  padding: 1.125rem var(--sai-size-4);
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__cta:hover:not(:disabled) {
  background: var(--sai-q0zon0xy-cta-bg);
  color: var(--sai-q0zon0xy-cta-fg);
  border: 1.5px solid var(--sai-q0zon0xy-cta-border);
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__cta:disabled {
  opacity: 0.45;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__total-heading {
  font-size: 1.5rem;
  font-weight: var(--sai-font-body-weight-bold, 700);
  letter-spacing: -0.01em;
  line-height: 1.2;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__total-subtext {
  font-size: 0.875rem;
  color: var(--sai-q0zon0xy-muted-fg);
  line-height: 1.4;
  text-align: start;
  flex: 0 1 auto;
  min-inline-size: 0;
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__total-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--sai-size-3);
  flex-wrap: nowrap;
}

@container sai-q0zon0xy (max-width: 540px) {
  .sai-q0zon0xy--horizontal .sai-q0zon0xy__total-row {
    flex-wrap: wrap;
  }
}

.sai-q0zon0xy--horizontal .sai-q0zon0xy__total-amount {
  margin-inline-start: auto;
  font-family: var(--sai-font-heading, var(--sai-font-body));
  font-size: 2rem;
