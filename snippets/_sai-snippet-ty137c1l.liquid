                  {%- endfor -%}
                  {%- if s_vid_url == '' -%}
                    {%- assign s_vid_url = s_vid_file.sources.first.url -%}
                  {%- endif -%}
                {%- elsif s_vid_file.url != blank -%}
                  {%- assign s_vid_url = s_vid_file.url -%}
                {%- endif -%}
                <video
