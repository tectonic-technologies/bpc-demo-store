  {%- comment -%} ── Lightbox: spotlight + thumbnail strip ── {%- endcomment -%}
  <dialog class="sai-ty137c1l__lightbox" aria-modal="true" aria-label="Product gallery">
    <div class="sai-ty137c1l__lightbox-header">
      <button class="sai-ty137c1l__lightbox-close" type="button" data-action="close-lightbox" aria-label="Close gallery">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
