        <button class="sai-ty137c1l__nav sai-ty137c1l__nav--next" type="button" aria-label="Next image" data-action="next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
            <path d="M9 18l6-7-6-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {%- endif -%}
    </div>

    {%- if asset_count > 1 -%}
      {%- if mobile_nav == 'thumbnails' -%}
        {%- comment -%} Mobile thumbnail strip — reuses the .__thumb button so the JS thumb sync (active class + scroll-into-view + click→goTo) drives it identically to the desktop strip. {%- endcomment -%}
        <div class="sai-ty137c1l__mobile-thumbs">
          {%- for handle in asset_handles -%}
            {%- if sai_native_gallery -%}
            {%- assign sai_mt = nil -%}
            {%- for media in product.media -%}
              {%- assign sai_mt_id = media.id | append: '' -%}
              {%- if sai_mt_id == handle -%}{%- assign sai_mt = media -%}{%- break -%}{%- endif -%}
            {%- endfor -%}
            {%- if sai_mt != blank -%}
              <button
                class="sai-ty137c1l__thumb{% if forloop.first %} sai-ty137c1l__thumb--active{% endif %}"
                type="button"
                data-index="{{ forloop.index0 }}"
                data-handle="{{ handle }}"
                aria-label="View image {{ forloop.index }}"
              >
                {%- if sai_mt.media_type == 'video' -%}
                  {%- if sai_mt.preview_image != blank -%}
                    <img class="sai-ty137c1l__thumb-media" src="{{ sai_mt.preview_image | image_url: width: 120 }}" alt="{{ sai_mt.alt | escape }}" loading="lazy" />
                  {%- endif -%}
                  <span class="sai-ty137c1l__thumb-play" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </span>
                {%- else -%}
                  <img class="sai-ty137c1l__thumb-media" src="{{ sai_mt.preview_image | image_url: width: 120 }}" alt="{{ sai_mt.alt | escape }}" loading="lazy" />
                {%- endif -%}
              </button>
            {%- endif -%}
            {%- else -%}
            {%- assign m_thumb_asset = nil -%}
            {%- for asset_ref in asset_list -%}
              {%- if asset_ref.system.handle == handle -%}
                {%- assign m_thumb_asset = asset_ref -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if m_thumb_asset != blank -%}
              <button
                class="sai-ty137c1l__thumb{% if forloop.first %} sai-ty137c1l__thumb--active{% endif %}"
                type="button"
                data-index="{{ forloop.index0 }}"
                data-handle="{{ handle }}"
                aria-label="View image {{ forloop.index }}"
              >
                {%- if m_thumb_asset.asset_type == 'video' -%}
                  {%- assign m_thumb_vid_file = m_thumb_asset.file.value | default: m_thumb_asset.file -%}
                  {%- if m_thumb_vid_file.preview_image != blank -%}
                    <img
                      class="sai-ty137c1l__thumb-media"
                      src="{{ m_thumb_vid_file.preview_image | image_url: width: 120 }}"
                      alt="{{ m_thumb_asset.alt | escape }}"
                      loading="lazy"
                    />
                  {%- endif -%}
                  <span class="sai-ty137c1l__thumb-play" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </span>
                {%- else -%}
                  <img
                    class="sai-ty137c1l__thumb-media"
                    src="{{ m_thumb_asset.file | image_url: width: 120 }}"
                    alt="{{ m_thumb_asset.alt | escape }}"
                    loading="lazy"
                  />
                {%- endif -%}
              </button>
            {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="sai-ty137c1l__dots">
          {%- for handle in asset_handles -%}
            <button
              class="sai-ty137c1l__dot{% if forloop.first %} sai-ty137c1l__dot--active{% endif %}"
