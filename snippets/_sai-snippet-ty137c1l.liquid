    <div class="sai-ty137c1l__lightbox-main">
      <div class="sai-ty137c1l__lightbox-spotlight"></div>
      <button class="sai-ty137c1l__lightbox-nav sai-ty137c1l__lightbox-nav--prev" type="button" data-action="lightbox-prev" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
