                />
              {%- endif -%}
              <span class="sai-ty137c1l__thumb-play" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </span>
            {%- else -%}
              <img
                class="sai-ty137c1l__thumb-media"
                src="{{ thumb_asset.file | image_url: width: 120 }}"
                alt="{{ thumb_asset.alt | escape }}"
                loading="lazy"
              />
            {%- endif -%}
          </button>
        {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} ── Mobile layout: spotlight + chevrons + dots ── {%- endcomment -%}
  <div class="sai-ty137c1l__mobile">
    <div class="sai-ty137c1l__mobile-spotlight-wrap">
      <div class="sai-ty137c1l__mobile-track">
        {%- for handle in asset_handles -%}
          {%- if sai_native_gallery -%}
          {%- assign sai_sm = nil -%}
