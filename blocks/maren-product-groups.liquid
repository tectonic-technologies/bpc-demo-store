{%- comment -%}
  MAREN · Product groups (shade / finish family swatch row) (PDP Kit)
  Primary: product.metafields.merch.product_group (metaobject, per schema.md:
    fields name, axis(shade/scent/size/style), members([{product, swatch, label}])).
    Each member links to a sibling product; the current product is marked active.
  Fallback: if no product_group is set, render the product's own first variant
    option as swatches that link to variant selection.
  Renders nothing if neither source yields swatches.
{%- endcomment -%}

{%- assign s = block.settings -%}
{%- assign group = product.metafields.merch.product_group.value -%}

{%- comment -%}
  Some sources store product_group as a metaobject_reference LIST. In that case
  `.value` is an array; take the first entry so `.members` resolves correctly.
{%- endcomment -%}
{%- if group.members == blank and group.first != blank and group.first.members != blank -%}
  {%- assign group = group.first -%}
{%- endif -%}

{%- comment -%}
  ---- Path A: product_group metaobject ----
  Count members that resolve to a real product AND are not just the current product.
  A group whose only member is this product is NOT a group — render nothing.
{%- endcomment -%}
{%- assign members = nil -%}
{%- assign real_member_count = 0 -%}
{%- if group != blank and group.members != blank and group.members.size > 0 -%}
  {%- for m in group.members -%}
    {%- if m.product != blank -%}
      {%- assign real_member_count = real_member_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if real_member_count > 1 -%}
    {%- assign members = group.members -%}
  {%- endif -%}
{%- endif -%}

{%- if members != blank -%}
  <section class="maren-pg" {{ block.shopify_attributes }}>
    {%- if s.show_heading -%}
      <p class="maren-pg__label">
        {%- if group.name != blank -%}{{ group.name }}{%- else -%}{{ s.heading }}{%- endif -%}
        {%- if group.axis != blank -%}<span class="maren-pg__axis">{{ group.axis }}</span>{%- endif -%}
      </p>
    {%- endif -%}
    <ul class="maren-pg__swatches" role="list">
      {%- for m in members -%}
        {%- assign mp = m.product -%}
        {%- if mp == blank -%}{%- continue -%}{%- endif -%}
        {%- assign is_active = false -%}
        {%- if mp.handle == product.handle -%}{%- assign is_active = true -%}{%- endif -%}
        {%- assign swatch_color = m.swatch | default: '' -%}
        {%- assign swatch_label = m.label | default: mp.title -%}
        <li class="maren-pg__item{% if is_active %} is-active{% endif %}">
          <a class="maren-pg__swatch" href="{{ mp.url }}" title="{{ swatch_label | escape }}"{% if is_active %} aria-current="true"{% endif %}>
            <span class="maren-pg__dot" style="--swatch: {{ swatch_color | default: 'currentColor' }};" aria-hidden="true"></span>
            <span class="maren-pg__name">{{ swatch_label }}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </section>

{%- comment -%}
  ---- Path B: fallback to this product's own variant shades ----
  Only treat the FIRST option as a swatch row when it is genuinely a
  shade/colour axis (name matches shade/color/colour/finish) AND it has more
  than one value. This prevents non-shade options (e.g. Size) from rendering a
  bogus swatch row, and prevents single-value options (e.g. a brush whose lone
  "Color" value is just the product name) from rendering an empty heading.
{%- endcomment -%}
{%- elsif s.fallback_to_variants and product.has_only_default_variant == false -%}
  {%- assign opt = product.options_with_values | first -%}
  {%- assign opt_name_lc = opt.name | downcase -%}
  {%- assign is_shade_axis = false -%}
  {%- if opt_name_lc contains 'shade' or opt_name_lc contains 'color' or opt_name_lc contains 'colour' or opt_name_lc contains 'finish' -%}
    {%- assign is_shade_axis = true -%}
  {%- endif -%}
  {%- if opt != blank and is_shade_axis and opt.values.size > 1 -%}
    <section class="maren-pg" {{ block.shopify_attributes }}>
      {%- if s.show_heading -%}
        <p class="maren-pg__label">{{ opt.name }}</p>
      {%- endif -%}
      <ul class="maren-pg__swatches" role="list">
        {%- for val in opt.values -%}
          {%- assign is_active = false -%}
          {%- if opt.selected_value == val -%}{%- assign is_active = true -%}{%- endif -%}
          {%- comment -%} Build a variant URL by matching the option position. {%- endcomment -%}
          {%- assign target = nil -%}
          {%- for v in product.variants -%}
            {%- if opt.position == 1 and v.option1 == val -%}{%- assign target = v -%}{%- break -%}
            {%- elsif opt.position == 2 and v.option2 == val -%}{%- assign target = v -%}{%- break -%}
            {%- elsif opt.position == 3 and v.option3 == val -%}{%- assign target = v -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          {%- assign vurl = product.url -%}
          {%- if target != blank -%}{%- assign vurl = product.url | append: '?variant=' | append: target.id -%}{%- endif -%}
          <li class="maren-pg__item{% if is_active %} is-active{% endif %}">
            <a class="maren-pg__swatch" href="{{ vurl }}" title="{{ val | escape }}"{% if is_active %} aria-current="true"{% endif %}>
              <span class="maren-pg__dot" style="--swatch: currentColor;" aria-hidden="true"></span>
              <span class="maren-pg__name">{{ val }}</span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </section>
  {%- endif -%}
{%- endif -%}

{% stylesheet %}
  .maren-pg { margin-block: var(--margin-md, 20px); color: var(--color-foreground, #2b2622); }
  .maren-pg__label { margin: 0 0 10px; font-size: 0.8rem; text-transform: lowercase; letter-spacing: 0.04em; opacity: 0.75; display: flex; align-items: baseline; gap: 8px; }
  .maren-pg__axis { font-size: 0.7rem; opacity: 0.6; }
  .maren-pg__swatches { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 10px; }
  .maren-pg__swatch { display: inline-flex; align-items: center; gap: 7px; text-decoration: none; color: inherit; font-size: 0.82rem; padding: 4px 6px; border-radius: 999px; border: 1px solid transparent; transition: border-color 0.15s ease; }
  .maren-pg__swatch:hover { border-color: color-mix(in srgb, currentColor 25%, transparent); }
  .maren-pg__item.is-active .maren-pg__swatch { border-color: color-mix(in srgb, currentColor 55%, transparent); }
  .maren-pg__dot { width: 18px; height: 18px; border-radius: 50%; background: var(--swatch, currentColor); box-shadow: inset 0 0 0 1px color-mix(in srgb, #000 12%, transparent); flex: none; }
  .maren-pg__name { line-height: 1; }
{% endstylesheet %}

{% schema %}
{
  "name": "MAREN · Product groups",
  "tag": null,
  "settings": [
    { "type": "paragraph", "content": "Shade or finish family swatches. Reads the merch.product_group metaobject from the MAREN data pipeline. Falls back to this product's own variant shades when no group is set. Renders nothing if neither is available." },
    { "type": "checkbox", "id": "show_heading", "label": "Show group label", "default": true },
    { "type": "text", "id": "heading", "label": "Fallback label (when group has no name)", "default": "Shades" },
    { "type": "checkbox", "id": "fallback_to_variants", "label": "Fall back to this product's variant shades", "default": true }
  ],
  "presets": [
    { "name": "MAREN · Product groups" }
  ]
}
{% endschema %}
