{%- comment -%}
  Spectrum FBT (feature recommendations_fbt, experience _system-155719762098)
  rendered in place of the native MAREN "Pairs well with" kit. The block slot
  in product.json is preserved so the position is unchanged; the body now
  hand-renders the Spectrum wrapper.

  NOT Studio-managed: this placement has no SPECTRUM_AI_SLOT markers in the
  owning section, so Studio will not rewrite or reposition it. Re-anchor in
  Studio if you want it managed again.

  Preview detection is re-derived here because {% render %} runs in an isolated
  scope and the section-scope _sai_preview / _sai_url do not propagate in.
{%- endcomment -%}

{%- capture _sai_url -%}{%- render '_sai-preview-detect' -%}{%- endcapture -%}
{%- assign _sai_preview = false -%}
{%- if _sai_url contains '_spectrum_ai_preview' -%}
  {%- assign _sai_preview = true -%}
{%- endif -%}

{%- unless request.design_mode -%}
{%- if _sai_preview and _sai_url contains '_spectrum_ai_preview=_system-155719762098' or _sai_url contains '|_system-155719762098|' -%}
  {% render '_sai-nx1wiedkk11ot9tjxe26tqxy', sai_state: 'draft' %}
{%- else -%}
  {% render '_sai-nx1wiedkk11ot9tjxe26tqxy', sai_state: 'live' %}
{%- endif -%}
{%- endunless -%}

{% schema %}
{
  "name": "MAREN · Bought together",
  "tag": null,
  "settings": [
    { "type": "paragraph", "content": "Frequently bought together. Now renders the Spectrum FBT snippet (feature recommendations_fbt) in place of the native MAREN kit." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pairs well with" },
    { "type": "checkbox", "id": "show_bulk_add", "label": "Show 'add selected to cart' button", "default": true }
  ],
  "presets": [
    { "name": "MAREN · Bought together" }
  ]
}
{% endschema %}
