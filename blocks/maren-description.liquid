{%- comment -%}
  Spectrum enriched product description (snippet epdsb4n7, experience
  _system-155719762098) rendered in the PDP details column in place of the
  native product-description block. The body hand-renders the Spectrum wrapper
  so the snippet sits inside the _product-details group instead of full-width
  at the section level.

  Content is Studio-driven: the wrapper reads product.metafields.spectrum.
  long_description_live and the snippet instance, so editing/visibility still
  flow from Studio. Only the placement is theme-pinned — there are no
  SPECTRUM_AI_SLOT markers here, so Studio will not reposition it.

  Preview detection is re-derived here because {% render %} runs in an isolated
  scope and the section-scope _sai_preview / _sai_url do not propagate in.
{%- endcomment -%}

{%- capture _sai_url -%}{%- render '_sai-preview-detect' -%}{%- endcapture -%}
{%- assign _sai_preview = false -%}
{%- if _sai_url contains '_spectrum_ai_preview' -%}
  {%- assign _sai_preview = true -%}
{%- endif -%}

{%- unless request.design_mode -%}
{%- if _sai_preview and _sai_url contains '_spectrum_ai_preview=_system-155719762098' or _sai_url contains '|_system-155719762098|' -%}
  {% render '_sai-vrfcij4233by78v051zno0dt', sai_state: 'draft' %}
{%- else -%}
  {% render '_sai-vrfcij4233by78v051zno0dt', sai_state: 'live' %}
{%- endif -%}
{%- endunless -%}

{% schema %}
{
  "name": "MAREN · Description",
  "tag": null,
  "settings": [
    { "type": "paragraph", "content": "Renders the Spectrum enriched product description (feature long_description) in the details column in place of the native product description." }
  ],
  "presets": [
    { "name": "MAREN · Description" }
  ]
}
{% endschema %}
